# ============================================================
# ECOLOOP — Environment Variables
# ============================================================
# HOW TO USE THIS FILE:
# 1. Copy this file and rename the copy to ".env.local"
#    (that exact name — Vite automatically loads it, and
#    .gitignore already makes sure it never gets shared/committed).
# 2. Fill in the two values below with your REAL Supabase
#    project values (you'll get these in Module 2, after you
#    create your free Supabase account and project).
# 3. Restart the dev server (npm run dev) after editing this
#    file — Vite only reads it on startup.
#
# WHERE TO FIND THESE VALUES IN SUPABASE:
# Supabase Dashboard -> your project -> Project Settings -> API
#   - "Project URL"        -> VITE_SUPABASE_URL
#   - "anon public" key    -> VITE_SUPABASE_ANON_KEY
# ============================================================

VITE_SUPABASE_URL="https://YOUR-PROJECT-ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"
